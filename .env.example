# Public browser-safe Supabase values
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Server-only Supabase key (never expose publicly)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# App passwords
SITE_PASSWORD=change-this-shared-guest-password
ADMIN_PASSWORD=change-this-separate-admin-password

# Email (optional for first deploy)
RESEND_API_KEY=YOUR_RESEND_API_KEY
FROM_EMAIL=Cottage Visit Calendar <noreply@yourdomain.com>
ADMIN_EMAILS=you@example.com,spouse@example.com
